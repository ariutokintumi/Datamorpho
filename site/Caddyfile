# Caddyfile for datamorpho.io
# Server: Caddy + php8.4-fpm
# Adjust the root path to match your server document root.

www.datamorpho.io {
    redir https://datamorpho.io{uri} permanent
}

datamorpho.io {
    root * /var/www/datamorpho.io/public
    encode gzip

    # Rewrite clean URLs to .php equivalents.
    # If the requested path has no matching file on disk, append .php and try again.
    # This makes /specification serve specification.php, /tools serve tools.php, etc.
    @notfile not file
    rewrite @notfile {path}.php

    # PHP-FPM handler (php8.4-fpm socket path — adjust if yours differs)
    php_fastcgi unix//run/php/php8.4-fpm.sock {
        index index.php
    }

    file_server
}
